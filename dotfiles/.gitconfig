[color]
  ui = true

[core]
  editor = vim
  excludesfile = ~/.gitignore

[github]
  user = dkinzer
[commit]
  gpgsign = false
  verbose = true
[init]
  defaultBranch = main
[pull]
  ff = only
[http]
	lowSpeedLimit = 1000
	lowSpeedTime = 600
[url "git@ssh.github.com:"]
	insteadOf = git@github.com:
